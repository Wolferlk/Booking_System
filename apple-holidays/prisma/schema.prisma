generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────

enum UserRole {
  BT_USER
  GT_USER
  TE_USER
  GT_TE_USER
  AC_USER
  CLIENT
  SUPER_ADMIN
  ULTRA_SUPER_ADMIN
}

enum OperationCountry {
  ALL
  VIETNAM
  SRILANKA
  SINGAPORE_MALAYSIA
}

enum BookingStatus {
  DRAFT
  BT_CONFIRMED
  GT_REVIEW
  CHANGE_REQUESTED
  GT_VERIFIED
  AWAITING_PAYMENT_CONFIRM
  OPERATIONS_READY
  CLIENT_LIVE
  IN_PROGRESS
  TE_REVIEWED
  DRIVER_ALLOCATED
  QC1_PASS
  TICKETS_ISSUED
  QC2_PASS
  MSG_SENT_CUSTOMER
  FEEDBACK_DONE
  COMPLETED
  CANCELLED
  AMENDED
}

enum ServiceType {
  PVT_TRANSFER
  SIC_TRANSFER
  OWN_ARRANGEMENT
}

enum TicketStatus {
  DRAFT
  PURCHASED
  PAID
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum ChangeRequestStatus {
  OPEN
  RESOLVED
}

enum PassengerType {
  ADULT
  CHILD
}

enum PNLCategory {
  HOTEL
  TICKETS
  GUIDES
  MEALS
  CRUISE
  WATER
  TRANSPORT
  TAX_FEES
  FLIGHT_TICKETS
  OTHER
}

enum DriverPaymentType {
  ADVANCE
  SALARY
  REIMBURSEMENT
  DEDUCTION
}

enum CreditPaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum MailboxKind {
  TOUR_CONFIRMATION
  PNL
}

enum MailMessageStatus {
  RECEIVED
  PROCESSED
  WAITING
  ERROR
}

// ─── User ────────────────────────────────────────────────────────────────

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String
  password      String           @db.Text
  role          UserRole
  country       OperationCountry @default(ALL)
  phone         String?
  avatar        String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  bookingsCreated   Booking[]       @relation("CreatedBy")
  statusEvents      StatusEvent[]
  changeRequests    ChangeRequest[] @relation("RaisedBy")
  payments          Payment[]       @relation("ProcessedBy")
  clientBookings    Booking[]       @relation("ClientUser")
  contactLogs       ContactLog[]
  reminders         Reminder[]
  activityLogs      ActivityLog[]
  driverPayments        DriverPayment[]       @relation("ProcessedByUser")
  creditAgentPayments   CreditAgentPayment[]  @relation("CreditPaymentProcessor")
  feedbackSaved         CustomerFeedback[]    @relation("FeedbackSavedBy")

  @@map("users")
}

// ─── Activity Log ─────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String   // BOOKING_CREATED | BOOKING_UPDATED | BOOKING_DELETED | STATUS_CHANGED | PAYMENT_CONFIRMED | TICKET_PURCHASED | LOGIN | etc.
  entityType  String?  // Booking | Payment | Ticket | Driver | User
  entityId    String?  // booking ref or entity id
  details     String?  @db.Text  // JSON with context
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Mail cache ──────────────────────────────────────────────────────────

model MailMessage {
  id             String           @id @default(cuid())
  graphId        String           @unique
  mailboxUser    String
  mailboxKind    MailboxKind
  uid            Int?
  subject        String
  fromAddress    String
  fromName       String
  toRecipients   Json?
  ccRecipients   Json?
  receivedAt     DateTime
  folder         String
  isRead         Boolean          @default(false)
  hasAttachments Boolean          @default(false)
  importance     String           @default("normal")
  conversationId String?
  type           String
  rawBody        String           @db.LongText
  bodyHtml       String           @db.LongText
  bookingRef       String?
  operationCountry OperationCountry?
  status           MailMessageStatus @default(RECEIVED)
  processedAt    DateTime?
  lastSyncedAt   DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdAt      DateTime         @default(now())

  @@index([mailboxUser, receivedAt])
  @@index([mailboxUser, status])
  @@index([bookingRef])
  @@map("mail_messages")
}

// ─── Booking ─────────────────────────────────────────────────────────────

model Booking {
  id                    String        @id @default(cuid())
  bookingRef            String        @unique
  agentBookingId        String?
  agent                 String?
  fileHandler           String?
  version               Int           @default(1)
  amendmentNote         String?       @db.Text
  status                BookingStatus @default(DRAFT)

  arrivalDate           DateTime
  departureDate         DateTime
  paxAdults             Int           @default(0)
  paxChildren           Int           @default(0)

  quotedTotal           Decimal?       @db.Decimal(10, 2)
  currency              String        @default("USD")
  cancellationDeadline  DateTime?

  terms                 String?       @db.Text
  exclusions            String?       @db.Text
  policyNotes           String?       @db.Text

  // Country this booking belongs to (detected from IS number / email subject)
  operationCountry      OperationCountry?

  // TC (Tour Confirmation) extracted fields
  isNumber              String?           // e.g. VN19005, IS48377, SG22232
  dealName              String?           // e.g. "Rakshitha - Vietnam - 060626"
  tourDestination       String?           // e.g. "Vietnam", "Sri Lanka"
  chauffeurContact      String?           @db.Text
  languagePreference    String?
  specialOccasions      String?           @db.Text
  checkedBy             String?
  reconfirmBy           String?

  // Agent contact details (extracted from email)
  agentEmail            String?
  agentPhone            String?
  agentWhatsapp         String?
  agentCountry          String?
  agentAddress          String?       @db.Text

  // Lead customer contact details (extracted from email)
  contactEmail          String?
  contactPhone          String?
  contactWhatsapp       String?
  contactCountry        String?
  contactAddress        String?       @db.Text

  sourceDocUrl          String?       @db.Text
  sourceDocName         String?

  // OneDrive folder link for this booking
  onedriveFolderUrl     String?       @db.Text

  clientPortalUnlockedAt DateTime?
  recheckCompletedAt    DateTime?
  recheckCompletedBy    String?

  // QC tracking
  qcPassedAt        DateTime?
  qcAutoEmailSentAt DateTime?
  qcAutoWaSentAt    DateTime?

  createdById           String
  createdBy             User          @relation("CreatedBy", fields: [createdById], references: [id])
  clientUserId          String?
  clientUser            User?         @relation("ClientUser", fields: [clientUserId], references: [id])

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  passengers            Passenger[]
  flights               Flight[]
  accommodations        Accommodation[]
  itineraryItems        ItineraryItem[]
  tourAgenda            TourAgenda?
  pnl                   PNL?
  payments              Payment[]
  changeRequests        ChangeRequest[]
  statusEvents          StatusEvent[]
  versions              BookingVersion[]
  emergencyContacts     EmergencyContact[]
  tickets               Ticket[]
  contactLogs           ContactLog[]
  customerFeedback      CustomerFeedback?
  externalPnlLink       ExternalPnlLink?

  @@index([status])
  @@index([arrivalDate])
  @@map("bookings")
}

// ─── Passengers ──────────────────────────────────────────────────────────

model Passenger {
  id          String        @id @default(cuid())
  bookingId   String
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name           String
  type           PassengerType @default(ADULT)
  age            Int?
  isLead         Boolean       @default(false)
  passport       String?
  nationality    String?
  contact        String?
  mealPreference String?

  @@map("passengers")
}

model EmergencyContact {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  role      String?

  @@map("emergency_contacts")
}

// ─── Flights ─────────────────────────────────────────────────────────────

model Flight {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  flightNo    String
  date        DateTime
  fromApt     String
  depTime     String
  toApt       String
  arrTime     String
  airline     String?
  notes       String?

  @@map("flights")
}

// ─── Accommodation ───────────────────────────────────────────────────────

model Accommodation {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  city        String
  hotel       String
  checkIn     DateTime
  checkOut    DateTime
  address     String?  @db.Text
  contact     String?
  nights      Int
  roomType    String?
  mealType    String?

  @@map("accommodations")
}

// ─── Itinerary Items ─────────────────────────────────────────────────────

model ItineraryItem {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  dayNo         Int
  date          DateTime
  title         String
  description   String?  @db.Text
  inclusions    String?  @db.Text
  exclusions    String?  @db.Text

  @@map("itinerary_items")
}

// ─── Tour Agenda ─────────────────────────────────────────────────────────

model TourAgenda {
  id        String       @id @default(cuid())
  bookingId String       @unique
  booking   Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  items     AgendaItem[]

  @@map("tour_agendas")
}

model AgendaItem {
  id           String      @id @default(cuid())
  agendaId     String
  agenda       TourAgenda  @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  date         DateTime
  location     String
  fromPoint    String?
  toPoint      String?
  details      String?     @db.Text
  mealPlan     String?
  meetingTime  String?
  serviceType  ServiceType @default(OWN_ARRANGEMENT)
  sortOrder    Int         @default(0)

  assignment   Assignment?
  tickets      Ticket[]

  @@map("agenda_items")
}

model Assignment {
  id            String         @id @default(cuid())
  agendaItemId  String         @unique
  agendaItem    AgendaItem     @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  driverId      String?
  driver        Driver?        @relation(fields: [driverId], references: [id])
  vendorId      String?
  vendor        VehicleVendor? @relation(fields: [vendorId], references: [id])
  vendorName    String?
  driverName    String?
  driverPhone   String?
  vehicleType   String?
  vehiclePlate  String?
  notes         String?        @db.Text
  driverRate    Decimal?       @db.Decimal(10,2)  // MMT cost rate for this movement
  rateCurrency  String?        @default("USD")
  waSentAt      DateTime?      // when the driver WhatsApp was last sent (for daily cron dedup)
  assignedAt    DateTime       @default(now())

  @@map("assignments")
}

// ─── Tickets ─────────────────────────────────────────────────────────────

model Ticket {
  id            String       @id @default(cuid())
  bookingId     String
  booking       Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  agendaItemId  String?
  agendaItem    AgendaItem?  @relation(fields: [agendaItemId], references: [id])
  pnlLineId     String?
  pnlLine       PNLLineItem? @relation(fields: [pnlLineId], references: [id])

  type          String
  qty           Int          @default(1)
  supplier      String?
  costPerUnit   Decimal?     @db.Decimal(10, 2)
  totalCost     Decimal?     @db.Decimal(10, 2)
  currency      String       @default("USD")
  status        TicketStatus @default(DRAFT)
  activated     Boolean      @default(true)   // false = auto-generated from P&L, pending GT activation
  purchasedAt   DateTime?
  reference     String?
  notes         String?      @db.Text

  // Manual category override (if null, falls back to pnlLine.category)
  category      String?

  // Transfer-specific details (for TRANSPORT category)
  transferType  String?      // SIC | PVT
  vehicleType   String?      // Car, Van, Bus, Minibus, Boat, etc.
  vehicleNumber String?      // Number plate
  driverName    String?
  driverPhone   String?

  // Ticket file upload (PDF or image)
  fileUrl       String?      @db.Text
  fileName      String?
  fileType      String?      // pdf | image

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("tickets")
}

// ─── P&L ─────────────────────────────────────────────────────────────────

model PNL {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paxAdults   Int           @default(0)
  paxChildren Int           @default(0)
  sourceDocUrl String?      @db.Text
  lockedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lineItems   PNLLineItem[]

  @@map("pnl")
}

model PNLLineItem {
  id              String      @id @default(cuid())
  pnlId           String
  pnl             PNL         @relation(fields: [pnlId], references: [id], onDelete: Cascade)
  activity        String
  category        PNLCategory @default(OTHER)
  mmtRate         Decimal     @db.Decimal(10, 2)
  sicRate         Decimal     @db.Decimal(10, 2) @default(0)
  pvtRatePP       Decimal     @db.Decimal(10, 2) @default(0)
  adEntrance      Decimal     @db.Decimal(10, 2) @default(0)
  chEntrance      Decimal     @db.Decimal(10, 2) @default(0)
  otherRate       Decimal     @db.Decimal(10, 2) @default(0)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentRefNumber String?
  paymentBillUrl  String?
  paymentBillName String?
  paymentConfirmedAt DateTime?
  paymentConfirmedBy String?
  sortOrder       Int         @default(0)
  notes           String?     @db.Text

  tickets         Ticket[]

  @@map("pnl_line_items")
}

// ─── Payments ────────────────────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type            String        // customer_payment | supplier_payment | advance | ticket_payment
  label           String?       // e.g. "Air Ticket - VN005 → SIN"
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  method          String?       // bank_transfer | card | cash | etc.
  status          PaymentStatus @default(PENDING)
  reference       String?       // internal ref
  refNumber       String?       // accounts-team-assigned ref number on confirmation
  notes           String?       @db.Text
  dueDate         DateTime?     // for scheduled payments
  paidAt          DateTime?
  processedById   String?
  processedBy     User?         @relation("ProcessedBy", fields: [processedById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

// ─── Change Requests ─────────────────────────────────────────────────────

model ChangeRequest {
  id          String              @id @default(cuid())
  bookingId   String
  booking     Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  raisedById  String
  raisedBy    User                @relation("RaisedBy", fields: [raisedById], references: [id])
  targetField String?
  notes       String              @db.Text
  status      ChangeRequestStatus @default(OPEN)
  resolvedAt  DateTime?
  resolvedNote String?            @db.Text
  createdAt   DateTime            @default(now())

  @@map("change_requests")
}

// ─── Status Events ───────────────────────────────────────────────────────

model StatusEvent {
  id          String        @id @default(cuid())
  bookingId   String
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromState   BookingStatus?
  toState     BookingStatus
  actorId     String
  actor       User          @relation(fields: [actorId], references: [id])
  note        String?       @db.Text
  createdAt   DateTime      @default(now())

  @@index([bookingId])
  @@map("status_events")
}

// ─── Booking Versions ────────────────────────────────────────────────────

model BookingVersion {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  versionNo     Int
  docSnapshot   String?  @db.LongText
  amendmentNote String?  @db.Text
  createdById   String
  createdAt     DateTime @default(now())

  @@map("booking_versions")
}

// ─── Contact Log & Reminders ──────────────────────────────────────────────

model ContactLog {
  id          String   @id @default(cuid())
  bookingId   String
  userId      String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
  type        String
  subject     String
  notes       String?  @db.Text
  contactedAt DateTime @default(now())

  @@map("contact_logs")
}

model Reminder {
  id          String   @id @default(cuid())
  bookingId   String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  title       String
  message     String?  @db.Text
  scheduledAt DateTime
  sentAt      DateTime?
  isDone      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("reminders")
}

// ─── Drivers & Vehicles ───────────────────────────────────────────────────
// 1 Vehicle ↔ 1 Driver

model Driver {
  id              String    @id @default(cuid())
  name            String
  phone           String
  email           String?
  licenseNo       String?
  isActive        Boolean   @default(true)
  photoUrl        String?   @db.Text

  // Vehicle link (1:1) — driver owns/uses this vehicle
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id])
  vehicleId       String?   @unique

  // Operation country (team scoping)
  country         OperationCountry?

  // Bank account details
  bankName        String?
  bankAccountNo   String?
  bankHolder      String?
  bankBranch      String?
  bankCode        String?

  // Advance balance tracking
  advanceBalance  Decimal   @default(0) @db.Decimal(10, 2)

  driverPayments  DriverPayment[]
  assignments     Assignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drivers")
}

model Vehicle {
  id           String   @id @default(cuid())
  type         String   // van | bus | car | minibus
  plateNo      String   @unique
  brand        String?  // Toyota, Ford, Mercedes etc.
  model        String?  // Hiace, Transit, Fortuner etc.
  capacity     Int
  description  String?
  photoOutside String?  @db.Text
  photoInside  String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  driver       Driver?  // reverse of Driver.vehicleId
  vendor       VehicleVendor? @relation(fields: [vendorId], references: [id])
  vendorId     String?

  @@map("vehicles")
}

model VehicleVendor {
  id          String            @id @default(cuid())
  name        String
  phone       String?
  email       String?
  address     String?
  isActive    Boolean           @default(true)
  country     OperationCountry?
  vehicles    Vehicle[]
  assignments Assignment[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("vehicle_vendors")
}

model DriverPayment {
  id          String            @id @default(cuid())
  driverId    String
  driver      Driver            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  amount      Decimal           @db.Decimal(10, 2)
  type        DriverPaymentType @default(ADVANCE)
  description String?
  refNumber   String?
  paidById    String
  paidBy      User              @relation("ProcessedByUser", fields: [paidById], references: [id])
  createdAt   DateTime          @default(now())

  @@index([driverId])
  @@map("driver_payments")
}

// ─── Credit Agents ───────────────────────────────────────────────────────
// Agents (e.g. MMT, MakeMyTrip, 30sundays) who pay in bulk on the 15th & 30th

model CreditAgent {
  id            String               @id @default(cuid())
  name          String               @unique
  aliases       String?              @db.Text  // JSON array of alternative names
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  creditLimit   Decimal?             @db.Decimal(10, 2)
  currency      String               @default("USD")
  notes         String?              @db.Text
  isActive      Boolean              @default(true)
  country       OperationCountry?

  payments      CreditAgentPayment[]

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("credit_agents")
}

model CreditAgentPayment {
  id            String              @id @default(cuid())
  agentId       String
  agent         CreditAgent         @relation(fields: [agentId], references: [id])

  // Period this payment covers
  periodStart   DateTime
  periodEnd     DateTime
  dueDate       DateTime            // the 15th or 30th it is due

  // Booking refs this payment settles (JSON array)
  bookingRefs   String?             @db.Text

  amountDue     Decimal             @db.Decimal(10, 2)
  amountPaid    Decimal             @default(0)             @db.Decimal(10, 2)
  currency      String              @default("USD")

  status        CreditPaymentStatus @default(PENDING)

  paidAt        DateTime?
  reference     String?
  notes         String?             @db.Text

  processedById String?
  processedBy   User?               @relation("CreditPaymentProcessor", fields: [processedById], references: [id])

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([agentId])
  @@map("credit_agent_payments")
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ─── WhatsApp Chat History ────────────────────────────────────────────────

model WhatsAppMessage {
  id          String   @id @default(cuid())
  bookingRef  String
  phone       String   // normalised E.164 without leading +
  direction   String   // outbound | inbound
  body        String   @db.Text
  waMessageId String?  // Meta's wamid — used for dedup on inbound
  status      String   @default("sent") // sent | received | failed
  senderName  String?  // staff display name (outbound) or contact name (inbound)
  createdAt   DateTime @default(now())

  @@index([bookingRef])
  @@index([phone])
  @@index([waMessageId])
  @@map("whatsapp_messages")
}

// ─── Customer Feedback ───────────────────────────────────────────────────

model CustomerFeedback {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rating      Int?
  comment     String?  @db.Text
  savedById   String
  savedBy     User     @relation("FeedbackSavedBy", fields: [savedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("customer_feedback")
}

// ─── OneDrive Integration ────────────────────────────────────────────────

enum OneDriveEventType {
  FOLDER_DETECTED
  TC_PROCESSED
  PNL_PROCESSED
  FILE_DETECTED
  ERROR
  SKIPPED
}

enum OneDriveEventStatus {
  PENDING
  PROCESSED
  ERROR
  SKIPPED
}

model OneDriveEvent {
  id           String              @id @default(cuid())
  driveType    String              // VN | SL | SG | MY
  itemId       String              // Graph item ID
  itemName     String              // file/folder name
  itemPath     String              @db.Text // full path in drive
  webUrl       String?             @db.Text
  eventType    OneDriveEventType
  bookingRef   String?
  status       OneDriveEventStatus @default(PENDING)
  errorMessage String?             @db.Text
  rawData      String?             @db.LongText
  processedAt  DateTime?
  createdAt    DateTime            @default(now())

  @@index([bookingRef])
  @@index([driveType, status])
  @@index([itemId])
  @@map("onedrive_events")
}

model OneDriveDeltaToken {
  driveKey  String   @id         // e.g. "VN" | "SL"
  token     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("onedrive_delta_tokens")
}

model AiUsageLog {
  id               String   @id @default(cuid())
  callType         String   // booking_extraction | pnl_extraction | pnl_classify | agenda_generation | ticket_details | ai_suggestion | onedrive_pnl_parse | other
  model            String   // gpt-4o | gpt-4o-mini
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Float
  bookingRef       String?
  source           String?  // email | onedrive | manual | api
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([callType])
  @@index([bookingRef])
  @@map("ai_usage_logs")
}

// ─── External PNL Link (Accounts team invoice_processor DB) ──────────────────

model ExternalPnlLink {
  id             String   @id @default(cuid())
  bookingId      String   @unique
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  externalPnlId  Int               // pnl_records.id in invoice_processor DB
  matchedBy      String            // "is_number" | "tour_ref" | "invoice_number" | "manual"
  matchedValue   String            // The value that triggered the match

  cachedRecord   Json              // Full pnl_records row snapshot
  cachedItems    Json              // pnl_items rows snapshot

  lastFetchedAt  DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([externalPnlId])
  @@map("external_pnl_links")
}
